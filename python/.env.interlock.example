# ACTI Edge Gateway — Interlock Bridge Configuration
# ===================================================
# Copy this file to /opt/aeg/.env.interlock on VM#2
# and adjust the values for your environment.

# ── TCP Server (PLC Listener) ──
AEG_LISTEN_HOST=0.0.0.0
AEG_LISTEN_PORT=5000
AEG_MAX_CONNECTIONS=50

# ── ACTILOCK Engine (VM#1) ──
AEG_ENGINE_HOST=192.168.1.1
AEG_ENGINE_PORT=3129
AEG_ENGINE_DOCUMENT=

# ── Defaults (from Admin UI) ──
AEG_DEFAULT_SITE=
AEG_DEFAULT_SYSTEM=
AEG_DEFAULT_RESOURCE=
AEG_DEFAULT_OPERATION=
AEG_DEFAULT_USER=

# ── FFI Library ──
AEG_LIB_PATH=/usr/lib/lib_actilock.so
AEG_FFI_TIMEOUT=10

# ── Laravel API ──
AEG_LARAVEL_URL=http://127.0.0.1:8000
AEG_API_TOKEN=
AEG_CONNECTION_ID=1

# ── Logging ──
AEG_LOG_LEVEL=INFO
AEG_LOG_FILE=/var/log/aeg/interlock_bridge.log

# ── Timeouts ──
AEG_TCP_READ_TIMEOUT=5
AEG_TCP_WRITE_TIMEOUT=5
AEG_MONITOR_INTERVAL=30
