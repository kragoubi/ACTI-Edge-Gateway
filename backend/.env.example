APP_NAME="ACTI Edge Gateway (AEG)"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=openmmes
DB_USERNAME=openmmes_user
DB_PASSWORD=openmmes_secret

# Server-side sessions (DB). The "cookie" driver stores session DATA in a cookie
# named after each session id, leaving a new cookie per login/regeneration — they
# pile up (hundreds) and bloat every request's headers. Keep this "database".
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Live sync over a single Reverb WebSocket (Pusher protocol). REVERB_HOST is the
# server-side publish target (the `reverb` service); clients connect via Caddy.
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=openmes
REVERB_APP_KEY=openmeskey
REVERB_APP_SECRET=openmessecret
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http

FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Sanctum SPA stateful domains (same-origin React app)
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:80,127.0.0.1,127.0.0.1:8000

# E2E test-control surface (see ../../e2e). Enables the gated /__e2e__/* tenant
# API and the test-only Electric tenant-scoping. Keep FALSE everywhere except a
# dedicated E2E test stack — it is also hard-disabled in production regardless.
E2E_CONTROL_ENABLED=false
